{
  "name": "local-opds",
  "version": "1.0.0",
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc -p tsconfig.json; cp -r reader/public dist/",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "ts-node --transpile-only test/buildfeed.test.ts"
  },
  "author": "Nikolas Maletschkin",
  "license": "ISC",
  "description": "A simple OPDS server that exposes a local directory structure as an OPDS (Atom) feed.",
  "keywords": [
    "opds",
    "ebook"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Tnxec2/local-opds-js"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jszip": "^3.4.1",
    "@types/node": "^25.9.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.10",
    "canvas": "^3.2.3",
    "express": "^5.2.1",
    "jszip": "^3.10.1",
    "node-fetch": "^2.7.0",
    "xml2js": "^0.6.2",
    "xmlbuilder2": "^4.0.3"
  }
}
